---
import KeepScrolling from "@/assets/keep-scrolling.svg";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.png" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>GTA VI Website</title>
    </head>
    <body>
        <slot />
        <KeepScrolling
            class="fixed bottom-3 right-0 left-0 mx-auto text-pink-300 drop-shadow-2xl animate-bounce-pulse"
        />
        <footer
            class="absolute bottom-0 left-0 right-0 z-[120] border-t border-white/15 bg-black/65 backdrop-blur-md"
        >
            <div
                class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-3 text-[11px] text-white/85 sm:flex-row sm:items-center sm:justify-between sm:text-xs"
            >
                <p class="text-balance">
                    Este sitio ha sido construido exclusivamente con fines educativos y de aprendizaje.
                    Todos los derechos sobre Grand Theft Auto, GTA VI, marcas, logos e imagenes asociadas
                    pertenecen a Rockstar Games y Take-Two Interactive.
                </p>
                <div class="flex items-center gap-4">
                    <a
                        href="https://github.com/Fr4n0m/gta-vi-website"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="rounded-full border border-white/30 px-3 py-1 font-semibold text-white transition-colors duration-300 hover:border-white hover:bg-white hover:text-black"
                    >
                        GitHub
                    </a>
                    <a
                        href="https://codebyfran.es"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-semibold text-yellow-100 underline underline-offset-4 hover:text-white"
                    >
                        Fr4n0m
                    </a>
                </div>
            </div>
        </footer>
    </body>
</html>

<style is:global>
    @import "tailwindcss";

    @theme {
        --font-sans: "GTA", system-ui, sans-serif;
        --font-narrow: "GTANarrow", system-ui, sans-serif;

        --animate-bounce-pulse: bounce-pulse 2s ease-in-out infinite;
    }

    @keyframes bounce-pulse {
        0% {
            transform: translateY(0);
            scale: 0.8;
            opacity: 0.8;
        }
        50% {
            transform: translateY(-5px);
            scale: 1;
            opacity: 1;
        }
        100% {
            transform: translateY(0);
            scale: 0.8;
            opacity: 0.8;
        }
    }

    body {
        background-color: #111;
        position: relative;
        height: 300vh;
        overflow-x: hidden;
        overscroll-behavior: none;
        color: #fff;
    }

    @font-face {
        font-family: GTA;
        src: url("/fonts/font-gta-regular.woff") format("woff");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: GTA;
        src: url("/fonts/font-gta-bold.woff") format("woff");
        font-weight: bold;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: GTA;
        src: url("/fonts/font-gta-semibold.woff") format("woff");
        font-weight: 600;
        font-style: normal;
        font-display: swap;
    }

    @font-face {
        font-family: GTANarrow;
        src: url("/fonts/font-gta-narrow.woff") format("woff");
        font-weight: normal;
        font-style: normal;
        font-display: swap;
    }
</style>
